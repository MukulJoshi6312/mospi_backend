PORT=4000
NODE_ENV=development

PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=MOSPI
PG_USER=postgres
PG_PASSWORD=postgres

JWT_ACCESS_SECRET=replace_me_with_a_long_random_string_access
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# Gmail SMTP (use a 16-char Google App Password, not your account password)
EMAIL_USER=
EMAIL_PASS=

# Frontend page that handles password reset; backend appends /<token>
FRONTEND_RESET_URL=http://localhost:5173/reset-password
PASSWORD_RESET_TTL_MIN=15
