# Server
PORT=5001
NODE_ENV=development

# Postgres
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=mospi_db
PG_USER=postgres
PG_PASSWORD=postgres

# Auth — access + refresh tokens
JWT_ACCESS_SECRET=change_me_access_secret_long_random
JWT_REFRESH_SECRET=change_me_refresh_secret_different_long_random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated frontend origins)
CORS_ORIGIN=http://localhost:3000

# Rate limits (requests per windowMs)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
